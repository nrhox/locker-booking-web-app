{
  "publicId": {
    "name": "id",
    "in": "path",
    "required": true,
    "description": "Public UUID/string identifier. Raw MongoDB ObjectId must not be exposed.",
    "schema": { "type": "string", "format": "uuid" }
  },
  "oauthProvider": {
    "name": "provider",
    "in": "path",
    "required": true,
    "description": "OAuth provider key resolved through provider abstraction.",
    "schema": {
      "type": "string",
      "enum": ["google", "github", "microsoft", "apple"]
    }
  },
  "page": {
    "name": "page",
    "in": "query",
    "required": false,
    "schema": { "type": "integer", "minimum": 1, "default": 1 }
  },
  "limit": {
    "name": "limit",
    "in": "query",
    "required": false,
    "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 10 }
  },
  "sort": {
    "name": "sort",
    "in": "query",
    "required": false,
    "description": "Comma-separated sort fields. Prefix with '-' for descending order, for example '-createdAt,startAt'.",
    "schema": { "type": "string" }
  },
  "locationStatus": {
    "name": "status",
    "in": "query",
    "required": false,
    "schema": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] }
  },
  "lockerStatus": {
    "name": "status",
    "in": "query",
    "required": false,
    "schema": {
      "type": "string",
      "enum": ["AVAILABLE", "MAINTENANCE", "DISABLED"]
    }
  },
  "bookingStatus": {
    "name": "status",
    "in": "query",
    "required": false,
    "schema": {
      "type": "string",
      "enum": ["ACTIVE", "COMPLETED", "CANCELLED", "EXPIRED"]
    }
  },
  "from": {
    "name": "from",
    "in": "query",
    "required": false,
    "description": "Inclusive lower datetime bound in ISO 8601 UTC.",
    "schema": { "type": "string", "format": "date-time" }
  },
  "to": {
    "name": "to",
    "in": "query",
    "required": false,
    "description": "Exclusive upper datetime bound in ISO 8601 UTC.",
    "schema": { "type": "string", "format": "date-time" }
  }
}
