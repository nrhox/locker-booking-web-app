{
  "authRefresh": {
    "post": {
      "tags": ["Auth"],
      "operationId": "refreshAuthToken",
      "summary": "Refresh JWT access token",
      "description": "Issues a new JWT access token using a valid refresh token. Refresh tokens should be rotated and stored server-side only as hashes.",
      "security": [],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "../schemas/refresh-token-request.json" }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Token refreshed successfully.",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["message", "data"],
                "additionalProperties": false,
                "properties": {
                  "message": { "type": "string", "examples": ["Token refreshed successfully"] },
                  "data": { "$ref": "../schemas/token-pair.json" }
                }
              }
            }
          }
        },
        "401": { "$ref": "../components/responses.json#/Unauthorized" },
        "422": { "$ref": "../components/responses.json#/UnprocessableEntity" }
      }
    }
  },
  "authLogout": {
    "post": {
      "tags": ["Auth"],
      "operationId": "logout",
      "summary": "Logout current session",
      "description": "Revokes a refresh token. When logoutAllDevices is true, all active refresh sessions for the user are revoked.",
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "../schemas/logout-request.json" }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Logged out successfully.",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["message", "data"],
                "additionalProperties": false,
                "properties": {
                  "message": { "type": "string", "examples": ["Logged out successfully"] },
                  "data": {
                    "type": "object",
                    "required": ["revoked"],
                    "additionalProperties": false,
                    "properties": { "revoked": { "type": "boolean" } }
                  }
                }
              }
            }
          }
        },
        "401": { "$ref": "../components/responses.json#/Unauthorized" },
        "422": { "$ref": "../components/responses.json#/UnprocessableEntity" }
      }
    }
  },
  "authMe": {
    "get": {
      "tags": ["Auth"],
      "operationId": "getCurrentUser",
      "summary": "Get authenticated user",
      "responses": {
        "200": {
          "description": "Current user returned.",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["message", "data"],
                "additionalProperties": false,
                "properties": {
                  "message": { "type": "string", "examples": ["Success"] },
                  "data": { "$ref": "../schemas/user.json" }
                }
              }
            }
          }
        },
        "401": { "$ref": "../components/responses.json#/Unauthorized" }
      }
    }
  }
}
