{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.example.com/schemas/locker-visualization.json",
  "type": "object",
  "required": ["locationId", "generatedAt", "lockers"],
  "additionalProperties": false,
  "properties": {
    "locationId": { "type": "string", "format": "uuid" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "lockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "code", "lockerStatus", "visualizationStatus"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "code": { "type": "string" },
          "label": { "type": ["string", "null"] },
          "lockerStatus": { "type": "string", "enum": ["AVAILABLE", "MAINTENANCE", "DISABLED"] },
          "visualizationStatus": {
            "type": "string",
            "enum": ["AVAILABLE", "OCCUPIED", "MY_BOOKING"],
            "description": "Derived at request time from active bookings, current user ownership, and permanent locker status. This value is not persisted."
          },
          "position": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "row": { "type": "integer", "minimum": 1 },
              "column": { "type": "integer", "minimum": 1 }
            }
          },
          "activeBookingId": {
            "type": ["string", "null"],
            "format": "uuid",
            "description": "Returned only for the current user's own active booking; otherwise null."
          }
        }
      }
    }
  }
}
