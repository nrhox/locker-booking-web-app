{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.example.com/schemas/error-response.json",
  "type": "object",
  "required": ["message"],
  "additionalProperties": false,
  "properties": {
    "message": { "type": "string", "examples": ["Validation error"] },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "message"],
        "additionalProperties": false,
        "properties": {
          "field": { "type": "string", "examples": ["startAt"] },
          "message": {
            "type": "string",
            "examples": ["Booking start time must be before end time"]
          }
        }
      },
      "default": []
    }
  }
}
