{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.example.com/schemas/location.json",
  "type": "object",
  "required": ["id", "name", "code", "status", "timezone", "createdAt", "updatedAt"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "name": { "type": "string", "minLength": 1, "examples": ["Main Library"] },
    "code": { "type": "string", "pattern": "^[A-Z0-9_-]{2,32}$", "examples": ["LIBRARY_A"] },
    "description": { "type": ["string", "null"] },
    "address": { "type": ["string", "null"] },
    "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] },
    "timezone": { "type": "string", "examples": ["Asia/Jakarta"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
