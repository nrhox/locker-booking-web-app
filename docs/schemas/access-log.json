{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.example.com/schemas/access-log.json",
  "type": "object",
  "required": ["id", "userId", "lockerId", "bookingId", "action", "requestedAt", "allowed"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "userId": { "type": "string", "format": "uuid" },
    "lockerId": { "type": "string", "format": "uuid" },
    "bookingId": { "type": "string", "format": "uuid" },
    "action": { "type": "string", "enum": ["OPEN", "CLOSE"] },
    "requestedAt": { "type": "string", "format": "date-time" },
    "allowed": { "type": "boolean" },
    "deniedReason": { "type": ["string", "null"], "examples": ["OPEN_RATE_LIMIT_3_MINUTES"] }
  }
}
